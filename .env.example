# Symphony environment — copy to .env and edit. All keys are OPTIONAL; with none set the server
# binds localhost with no auth (the historical single-user default). See docs/DEPLOYMENT.md.

# ── Network & access control (SYM-42) ─────────────────────────────────────────────────────────
# Interface to bind. Default is localhost (secure: nothing on the LAN can reach it). Set 0.0.0.0
# (or a specific IP) for LAN access — but then a token is required or the server refuses to start.
# HOST=0.0.0.0

# Server port (default 3030).
# PORT=3030

# Shared secret that turns on the minimal access-control gate (HTTP Basic / Bearer / ?token=).
# Unset ⇒ no auth. Required to bind a non-loopback HOST. Choose a long random value.
# SYMPHONY_AUTH_TOKEN=change-me-to-a-long-random-secret

# Escape hatch: bind a non-loopback HOST WITHOUT a token (downgrades the refusal to a warning).
# Unsafe — bypassPermissions agents = arbitrary command execution on the host. Trusted LANs only.
# SYMPHONY_ALLOW_INSECURE_LAN=1

# Vite dev-server bind (dev only): `true` = all interfaces, or a literal host. Default localhost.
# SYMPHONY_WEB_HOST=true

# ── Storage paths ─────────────────────────────────────────────────────────────────────────────
# SYMPHONY_DATA_DIR=./data
# SYMPHONY_DB_PATH=./data/symphony.db
# SYMPHONY_WORKSPACE_ROOT=/tmp/symphony_workspaces
